/* Geração de Código Final — ciclo 'enquanto' (while) */
/* O ciclo deve iterar enquanto i <= 5 e escrever cada valor. */
/* Output esperado: 1, 2, 3, 4, 5. */
vazio principal(vazio);

vazio principal(vazio) {
    inteiro i = 1;
    enquanto (i <= 5) {
        escrever(i);
        i = i + 1;
    }
}
