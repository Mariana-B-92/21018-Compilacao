/* Redefinição de Função */
/* Regra: Cada função só pode ser definida uma vez no programa. - inválido */
inteiro soma(inteiro, inteiro);
vazio principal(vazio);

inteiro soma(inteiro a, inteiro b) {
    retornar a + b;
}

inteiro soma(inteiro a, inteiro b) {
    retornar a * b;
}

vazio principal(vazio) {
    escrever(soma(1, 2));
}