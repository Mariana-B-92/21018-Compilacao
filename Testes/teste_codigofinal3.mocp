/* Geração de Código Final — operador menor (<) */
/* CMP seguido de JMP.N, materializando o booleano em R1. */
/* Output esperado: 1, 0. */
vazio principal(vazio);

vazio principal(vazio) {
    inteiro a = 3, b = 5;
    se (a < b) { escrever(1); } senao { escrever(0); }
    se (b < a) { escrever(1); } senao { escrever(0); }
}
